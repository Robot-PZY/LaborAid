# =============================================================================
# 劳权智助 · LaborAid — 本地开发环境配置
# 配置位置说明：docs/api-config-locations.md
# Maintained by Pulse Peng
# =============================================================================

APP_NAME=LaborAid
ENVIRONMENT=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-local
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./laboraid.db
DATABASE_URL_SYNC=sqlite:///./laboraid.db

JWT_SECRET_KEY=dev-jwt-secret-local
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# 管理员邮箱（逗号分隔，注册/登录后自动获得 admin 角色）
ADMIN_EMAIL=

# 首次启动自动创建的初始管理员（登录可用账号名 Admin 或下方邮箱）
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_EMAIL=admin@laboraid.local
INITIAL_ADMIN_PASSWORD=123456

# ── LLM 大模型（必填）──────────────────────────────────────────
LLM_API_KEY=                          # ← 在此填入 API Key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=8192

# 阿里百炼 OCR（图片文字识别）https://bailian.console.aliyun.com/
VISION_LLM_API_KEY=
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_MODEL=qwen-vl-ocr-latest
VISION_LLM_MAX_TOKENS=4096

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=laboraid_docs
CHINESE_LAW_MCP_ENABLED=true
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BASE_URL=

# ── 企业风险扫描（可选，企查查 736）──────────────────────────────
QICHACHA_API_KEY=                    # ← 企查查 AppKey
QICHACHA_SECRET_KEY=                 # ← 企查查 SecretKey
QICHACHA_API_URL=https://api.qichacha.com

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
