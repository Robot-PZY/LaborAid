# =============================================================================
# 劳权智助 · LaborAid — Environment Configuration
# =============================================================================
# 复制为 backend/.env 后填入 API Key
# 配置位置说明：docs/api-config-locations.md
# Maintained by Pulse Peng

APP_NAME=LaborAid
ENVIRONMENT=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8010

DATABASE_URL=sqlite+aiosqlite:///./LaborAid.db
DATABASE_URL_SYNC=sqlite:///./LaborAid.db

JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM 大模型（必填）──────────────────────────────────────────
LLM_API_KEY=                          # ← 在此填入 API Key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=8192

# 旧版变量名（可选，LLM_* 未设置时生效）：
# CLAUDE_API_KEY=
# CLAUDE_BASE_URL=
# CLAUDE_MODEL=

# ── 视觉 / OCR（阿里通义千问 VL，与文本 LLM 分离）────────────────
# 申请：https://dashscope.aliyun.com/
VISION_LLM_API_KEY=
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_MODEL=qwen-vl-ocr-latest
VISION_LLM_MAX_TOKENS=4096

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=LaborAid_docs
CHINESE_LAW_MCP_ENABLED=true

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BASE_URL=                   # ← 自定义 Embedding API（可选）

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:5320,http://127.0.0.1:5320,http://localhost:3000

# ── 知识库官方法规定时同步（每周日 03:00，本地时区）────────────
KNOWLEDGE_CRAWL_SCHEDULE_ENABLED=true
KNOWLEDGE_CRAWL_WEEKDAY=6
KNOWLEDGE_CRAWL_HOUR=3
KNOWLEDGE_CRAWL_MINUTE=0

LOG_LEVEL=INFO
LOG_FILE=

# ── 外部 API（可选，预留）────────────────────────────────────
# TIANYANCHA_API_KEY=
# QICHACHA_API_KEY=
# QICHACHA_SECRET_KEY=
# QICHACHA_API_URL=https://api.qichacha.com

# 得理法律开放平台（法规/案例检索，可选）
DELILEGAL_ENABLED=false
DELILEGAL_BASE_URL=https://openapi.delilegal.com
DELILEGAL_APPID=
DELILEGAL_SECRET=
